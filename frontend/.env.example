# ── AttnRes Chat — environment configuration ──────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# All keys MUST carry the ATTNRES_ prefix — that is how Pydantic Settings
# maps them to the Settings fields (env_prefix = "ATTNRES_").
#
# The .env file is resolved relative to app/config.py, so it is always found
# at frontend/.env regardless of the working directory you launch from.

# ── Server ────────────────────────────────────────────────────────────────
ATTNRES_PORT=8080
ATTNRES_WORKERS=1
ATTNRES_LOG_LEVEL=info
ATTNRES_DEVICE=auto                         # auto | cpu | cuda

# ── Paths ─────────────────────────────────────────────────────────────────
ATTNRES_CHECKPOINTS_DIR=../checkpoints      # host path mounted into the container

# ── Auth (CHANGE ALL OF THESE) ────────────────────────────────────────────
ATTNRES_AUTH_USERNAME=admin
ATTNRES_AUTH_PASSWORD=changeme

# Preferred: use a bcrypt hash instead of a plain password.
# Generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('mypassword'))"
# When set, ATTNRES_AUTH_PASSWORD is ignored.
ATTNRES_AUTH_PASSWORD_HASH=

# Generate with: openssl rand -hex 32
ATTNRES_SECRET_KEY=CHANGE-THIS-IN-PRODUCTION

ATTNRES_SESSION_EXPIRE_MINUTES=300          # 5 hours

# ── Generation ────────────────────────────────────────────────────────────
ATTNRES_MAX_NEW_TOKENS_LIMIT=2048

# ── Container image (used by docker-compose.yml and Makefile) ─────────────
IMAGE_NAME=attnres-chat
IMAGE_TAG=latest
